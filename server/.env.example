# Porta principal da API
PORT=3333

# Endereco do frontend autorizado a conversar com a API
CLIENT_URL=http://localhost:5173

# Endereco publico usado para montar links de arquivos e uploads
SERVER_PUBLIC_URL=http://localhost:3333

# Chave de acesso usada na assinatura dos tokens JWT
JWT_SECRET=chave_de_acesso_do_sistema

# Endereco do servidor MySQL
DB_HOST=localhost

# Porta do MySQL
DB_PORT=3306

# Nome do banco de dados da aplicacao
DB_NAME=controller_financeiro

# Usuario do banco de dados
DB_USER=usuario_do_banco

# Senha do banco de dados
DB_PASSWORD=senha_do_banco

# Servidor SMTP usado no envio de e-mail
SMTP_HOST=smtp.gmail.com

# Porta do servidor SMTP
SMTP_PORT=587

# Conta de e-mail responsavel pelos envios
SMTP_USER=seuemail@empresa.com

# Senha da conta SMTP ou senha de app
SMTP_PASS=senha_do_email_ou_senha_de_app

# Nome e remetente visivel no envio
SMTP_FROM="Controller Financeiro <no-reply@example.com>"

# Nome da conta Cloudinary
CLOUDINARY_CLOUD_NAME=nome_da_conta_cloudinary

# Chave publica da conta Cloudinary
CLOUDINARY_API_KEY=chave_publica_cloudinary

# Chave secreta da conta Cloudinary
CLOUDINARY_API_SECRET=chave_secreta_cloudinary
